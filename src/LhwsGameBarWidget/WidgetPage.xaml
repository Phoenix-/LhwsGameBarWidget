<Page
    x:Class="LhwsGameBarWidget.WidgetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LhwsGameBarWidget"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Stock WUX ProgressBar draws square rectangles and ignores CornerRadius;
             retemplate with a pill track + indicator (control drives the width of
             the part named ProgressBarIndicator). -->
        <Style x:Key="RoundedBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="2"/>
                            <Rectangle x:Name="ProgressBarIndicator"
                                       Fill="{TemplateBinding Foreground}"
                                       RadiusX="2" RadiusY="2"
                                       HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Padding="12,8,12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="StatusText"
                   Text="Connecting to LibreHardwareService…"
                   Style="{StaticResource CaptionTextBlockStyle}"
                   Opacity="0.6"
                   Margin="4,0,4,4"/>

        <ListView x:Name="SensorList"
                  Grid.Row="1"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  ScrollViewer.VerticalScrollBarVisibility="Hidden">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="MinHeight" Value="40"/>
                    <Setter Property="Padding" Value="4,4,4,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:CompositeRow">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid>
                            <!-- Equal star columns flanking the Auto column keep the
                                 temperature exactly centered in the row -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind Name}"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{x:Bind CenterText, Mode=OneWay}"
                                       Foreground="{x:Bind CenterBrush, Mode=OneWay}"
                                       VerticalAlignment="Center"
                                       Margin="8,0"/>
                            <TextBlock Grid.Column="2"
                                       Text="{x:Bind RightText, Mode=OneWay}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </Grid>
                        <ProgressBar Grid.Row="1"
                                     Style="{StaticResource RoundedBarStyle}"
                                     Minimum="0" Maximum="100"
                                     Value="{x:Bind BarValue, Mode=OneWay}"
                                     Visibility="{x:Bind BarVisibility}"
                                     Height="4"
                                     Margin="0,4,0,0"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <StackPanel x:Name="EmptyState"
                    Grid.Row="1"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8"
                    Visibility="Collapsed">
            <TextBlock Text="No rows configured"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Open widget settings (⚙ in the title bar) and add sensor rows."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Opacity="0.7"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="240"/>
        </StackPanel>
    </Grid>
</Page>
